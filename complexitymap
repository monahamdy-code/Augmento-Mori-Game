<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Death Complexity Map — Augmento Mori</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=DM+Mono:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0a0a0f;
    --surface: #111118;
    --border: rgba(255,255,255,0.07);
    --text: #e8e4d8;
    --muted: #7a7570;
    --am-core: #c4513a;
    --am-glow: rgba(196, 81, 58, 0.18);
    --hb-core: #4a8fa8;
    --hb-glow: rgba(74, 143, 168, 0.18);
    --neutral: #8a8060;
    --system: rgba(200,190,160,0.12);
    --loop-r: rgba(220, 100, 60, 0.35);
    --loop-b: rgba(60, 140, 180, 0.35);
    --gold: #c8a96e;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* Grain overlay */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 1000;
    opacity: 0.6;
  }

  header {
    padding: 32px 40px 20px;
    border-bottom: 1px solid var(--border);
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
  }

  .header-left h1 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 28px;
    font-weight: 300;
    letter-spacing: 0.02em;
    color: var(--text);
    line-height: 1.1;
  }

  .header-left h1 em {
    font-style: italic;
    color: var(--gold);
  }

  .header-left p {
    font-size: 10px;
    color: var(--muted);
    margin-top: 6px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .legend {
    display: flex;
    gap: 24px;
    align-items: center;
  }

  .legend-item {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 10px;
    color: var(--muted);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .legend-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }

  .legend-line {
    width: 24px;
    height: 2px;
    border-radius: 1px;
  }

  /* Main canvas */
  .canvas {
    position: relative;
    width: 100%;
    padding: 40px;
  }

  svg#map {
    width: 100%;
    height: 680px;
    display: block;
  }

  /* Tooltip */
  .tooltip {
    position: fixed;
    background: #1a1a22;
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 14px 18px;
    max-width: 280px;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.2s;
    z-index: 999;
  }

  .tooltip.visible { opacity: 1; }

  .tooltip-tag {
    font-size: 9px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 6px;
    font-weight: 500;
  }

  .tooltip-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 16px;
    font-weight: 400;
    color: var(--text);
    margin-bottom: 8px;
    line-height: 1.2;
  }

  .tooltip-body {
    font-size: 10.5px;
    color: #9d9890;
    line-height: 1.65;
  }

  .tooltip-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    margin-top: 10px;
  }

  .tooltip-pill {
    background: rgba(255,255,255,0.05);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 2px 8px;
    font-size: 9px;
    color: var(--muted);
    letter-spacing: 0.06em;
  }

  /* Panel below map */
  .panels {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    border-top: 1px solid var(--border);
    background: var(--border);
  }

  .panel {
    background: var(--bg);
    padding: 32px 40px;
  }

  .panel-header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 20px;
  }

  .panel-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .panel-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 20px;
    font-weight: 400;
    letter-spacing: 0.02em;
  }

  .panel-subtitle {
    font-size: 9px;
    color: var(--muted);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-top: 2px;
  }

  .panel-body {
    font-size: 11px;
    color: #9d9890;
    line-height: 1.75;
  }

  .panel-body strong {
    color: var(--text);
    font-weight: 500;
  }

  .touchpoints {
    margin-top: 16px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .touchpoint {
    display: flex;
    gap: 10px;
    align-items: flex-start;
  }

  .tp-arrow {
    flex-shrink: 0;
    margin-top: 2px;
    opacity: 0.5;
  }

  .tp-text {
    font-size: 10.5px;
    color: #9d9890;
    line-height: 1.55;
  }

  .tp-text span {
    color: var(--text);
    font-weight: 500;
  }

  .divider {
    border: none;
    border-top: 1px solid var(--border);
    margin: 20px 0;
  }

  footer {
    padding: 16px 40px;
    border-top: 1px solid var(--border);
    font-size: 9.5px;
    color: var(--muted);
    letter-spacing: 0.05em;
    display: flex;
    justify-content: space-between;
  }

  /* Pulse animation for key nodes */
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.6; }
  }

  @keyframes spin-slow {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  .node-interactive {
    cursor: pointer;
    transition: all 0.2s;
  }

  .node-interactive:hover circle:first-of-type {
    filter: brightness(1.3);
  }
</style>
</head>
<body>

<header>
  <div class="header-left">
    <h1><em>Augmento Mori</em> — Death Complexity Map</h1>
    <p>Kastenbaum / Lancet Commission Framework &nbsp;·&nbsp; Design Interventions Overlay &nbsp;·&nbsp; Mona M. Hamdy, SCAD MFA 2026</p>
  </div>
  <div class="legend">
    <div class="legend-item">
      <div class="legend-dot" style="background: var(--am-core);"></div>
      Augmento Mori
    </div>
    <div class="legend-item">
      <div class="legend-dot" style="background: var(--hb-core);"></div>
      HeartBloom
    </div>
    <div class="legend-item">
      <div class="legend-line" style="background: var(--loop-r);"></div>
      Reinforcing loop
    </div>
    <div class="legend-item">
      <div class="legend-line" style="background: var(--loop-b);"></div>
      Balancing loop
    </div>
    <div class="legend-item">
      <div class="legend-dot" style="background: rgba(200,190,160,0.4);"></div>
      System node
    </div>
  </div>
</header>

<div class="canvas">
  <svg id="map" viewBox="0 0 1100 680">
    <defs>
      <!-- Gradients -->
      <radialGradient id="am-glow" cx="50%" cy="50%" r="50%">
        <stop offset="0%" stop-color="#c4513a" stop-opacity="0.3"/>
        <stop offset="100%" stop-color="#c4513a" stop-opacity="0"/>
      </radialGradient>
      <radialGradient id="hb-glow" cx="50%" cy="50%" r="50%">
        <stop offset="0%" stop-color="#4a8fa8" stop-opacity="0.25"/>
        <stop offset="100%" stop-color="#4a8fa8" stop-opacity="0"/>
      </radialGradient>
      <radialGradient id="center-glow" cx="50%" cy="50%" r="50%">
        <stop offset="0%" stop-color="#c8a96e" stop-opacity="0.15"/>
        <stop offset="100%" stop-color="#c8a96e" stop-opacity="0"/>
      </radialGradient>
      <radialGradient id="bg-field" cx="50%" cy="50%" r="50%">
        <stop offset="0%" stop-color="#1a1820" stop-opacity="1"/>
        <stop offset="100%" stop-color="#0a0a0f" stop-opacity="1"/>
      </radialGradient>

      <!-- Arrowheads -->
      <marker id="arrow-r" markerWidth="6" markerHeight="6" refX="5" refY="3" orient="auto">
        <path d="M0,0 L6,3 L0,6 Z" fill="rgba(220,100,60,0.5)"/>
      </marker>
      <marker id="arrow-b" markerWidth="6" markerHeight="6" refX="5" refY="3" orient="auto">
        <path d="M0,0 L6,3 L0,6 Z" fill="rgba(60,140,180,0.5)"/>
      </marker>
      <marker id="arrow-n" markerWidth="6" markerHeight="6" refX="5" refY="3" orient="auto">
        <path d="M0,0 L6,3 L0,6 Z" fill="rgba(200,190,160,0.3)"/>
      </marker>
      <marker id="arrow-am" markerWidth="7" markerHeight="7" refX="5" refY="3.5" orient="auto">
        <path d="M0,0 L7,3.5 L0,7 Z" fill="#c4513a"/>
      </marker>
      <marker id="arrow-hb" markerWidth="7" markerHeight="7" refX="5" refY="3.5" orient="auto">
        <path d="M0,0 L7,3.5 L0,7 Z" fill="#4a8fa8"/>
      </marker>

      <!-- Blur filter -->
      <filter id="glow-soft">
        <feGaussianBlur stdDeviation="6" result="blur"/>
        <feComposite in="SourceGraphic" in2="blur" operator="over"/>
      </filter>
      <filter id="glow-node">
        <feGaussianBlur stdDeviation="3" result="blur"/>
        <feComposite in="SourceGraphic" in2="blur" operator="over"/>
      </filter>
    </defs>

    <!-- Background -->
    <rect width="1100" height="680" fill="url(#bg-field)"/>

    <!-- Outer system boundary ellipse -->
    <ellipse cx="550" cy="340" rx="500" ry="290" fill="none" stroke="rgba(200,190,160,0.06)" stroke-width="1" stroke-dasharray="4 6"/>
    <ellipse cx="550" cy="340" rx="460" ry="255" fill="none" stroke="rgba(200,190,160,0.04)" stroke-width="1"/>

    <!-- Zone labels -->
    <text x="60" y="70" fill="rgba(200,190,160,0.18)" font-family="DM Mono, monospace" font-size="9" letter-spacing="0.12em" text-transform="uppercase">SOCIOCULTURAL SYSTEM</text>
    <text x="60" y="84" fill="rgba(200,190,160,0.12)" font-family="DM Mono, monospace" font-size="8" letter-spacing="0.08em">beliefs · norms · taboo · policy · economics</text>

    <!-- ======= REINFORCING LOOPS (red-orange arcs) ======= -->
    <!-- Medicalization loop -->
    <path d="M 380 190 Q 490 130 600 165 Q 680 190 720 255" fill="none" stroke="rgba(220,100,60,0.3)" stroke-width="1.5" stroke-dasharray="3 4" marker-end="url(#arrow-r)"/>
    <!-- Avoidance loop -->
    <path d="M 280 290 Q 220 360 260 440 Q 300 500 380 490" fill="none" stroke="rgba(220,100,60,0.25)" stroke-width="1.5" stroke-dasharray="3 4" marker-end="url(#arrow-r)"/>
    <!-- Institutional reinforcement -->
    <path d="M 720 255 Q 800 320 790 430 Q 780 490 720 510" fill="none" stroke="rgba(220,100,60,0.25)" stroke-width="1.5" stroke-dasharray="3 4" marker-end="url(#arrow-r)"/>

    <!-- ======= BALANCING LOOPS (blue arcs) ======= -->
    <!-- Community care balancing -->
    <path d="M 380 490 Q 450 550 550 540 Q 640 530 700 490" fill="none" stroke="rgba(60,140,180,0.3)" stroke-width="1.5" stroke-dasharray="3 4" marker-end="url(#arrow-b)"/>
    <!-- Death literacy balancing -->
    <path d="M 280 290 Q 300 200 390 185" fill="none" stroke="rgba(60,140,180,0.25)" stroke-width="1.5" stroke-dasharray="3 4" marker-end="url(#arrow-b)"/>

    <!-- ======= SYSTEM NODES ======= -->
    <!-- 1: Death Avoidance / Taboo -->
    <g class="node-interactive" data-node="avoidance" transform="translate(250,280)">
      <circle r="32" fill="rgba(200,190,160,0.06)" stroke="rgba(200,190,160,0.2)" stroke-width="1"/>
      <circle r="16" fill="rgba(200,190,160,0.1)" stroke="rgba(200,190,160,0.3)" stroke-width="1"/>
      <text y="-40" text-anchor="middle" fill="rgba(200,190,160,0.65)" font-family="DM Mono, monospace" font-size="9" letter-spacing="0.06em">DEATH AVOIDANCE</text>
      <text y="-29" text-anchor="middle" fill="rgba(200,190,160,0.4)" font-family="DM Mono, monospace" font-size="8">taboo · silence · fear</text>
    </g>

    <!-- 2: Medicalization -->
    <g class="node-interactive" data-node="medicalization" transform="translate(660,200)">
      <circle r="36" fill="rgba(200,190,160,0.06)" stroke="rgba(200,190,160,0.2)" stroke-width="1"/>
      <circle r="18" fill="rgba(200,190,160,0.1)" stroke="rgba(200,190,160,0.3)" stroke-width="1"/>
      <text y="-46" text-anchor="middle" fill="rgba(200,190,160,0.65)" font-family="DM Mono, monospace" font-size="9" letter-spacing="0.06em">MEDICALIZATION</text>
      <text y="-35" text-anchor="middle" fill="rgba(200,190,160,0.4)" font-family="DM Mono, monospace" font-size="8">hospital · clinical · detached</text>
    </g>

    <!-- 3: Institutional Care -->
    <g class="node-interactive" data-node="institutional" transform="translate(790,380)">
      <circle r="30" fill="rgba(200,190,160,0.06)" stroke="rgba(200,190,160,0.18)" stroke-width="1"/>
      <circle r="15" fill="rgba(200,190,160,0.1)" stroke="rgba(200,190,160,0.3)" stroke-width="1"/>
      <text y="-40" text-anchor="middle" fill="rgba(200,190,160,0.65)" font-family="DM Mono, monospace" font-size="9" letter-spacing="0.06em">INSTITUTIONAL CARE</text>
      <text y="-29" text-anchor="middle" fill="rgba(200,190,160,0.4)" font-family="DM Mono, monospace" font-size="8">ICU · hospice · policy</text>
    </g>

    <!-- 4: Death Literacy -->
    <g class="node-interactive" data-node="literacy" transform="translate(390,170)">
      <circle r="28" fill="rgba(200,190,160,0.06)" stroke="rgba(200,190,160,0.18)" stroke-width="1"/>
      <circle r="13" fill="rgba(200,190,160,0.1)" stroke="rgba(200,190,160,0.3)" stroke-width="1"/>
      <text y="-38" text-anchor="middle" fill="rgba(200,190,160,0.65)" font-family="DM Mono, monospace" font-size="9" letter-spacing="0.06em">DEATH LITERACY</text>
      <text y="-27" text-anchor="middle" fill="rgba(200,190,160,0.4)" font-family="DM Mono, monospace" font-size="8">education · awareness</text>
    </g>

    <!-- 5: Community Networks -->
    <g class="node-interactive" data-node="community" transform="translate(500,510)">
      <circle r="30" fill="rgba(200,190,160,0.06)" stroke="rgba(200,190,160,0.18)" stroke-width="1"/>
      <circle r="14" fill="rgba(200,190,160,0.1)" stroke="rgba(200,190,160,0.3)" stroke-width="1"/>
      <text y="44" text-anchor="middle" fill="rgba(200,190,160,0.65)" font-family="DM Mono, monospace" font-size="9" letter-spacing="0.06em">COMMUNITY NETWORKS</text>
      <text y="55" text-anchor="middle" fill="rgba(200,190,160,0.4)" font-family="DM Mono, monospace" font-size="8">grief · ritual · belonging</text>
    </g>

    <!-- 6: Patient Autonomy -->
    <g class="node-interactive" data-node="autonomy" transform="translate(700,490)">
      <circle r="26" fill="rgba(200,190,160,0.06)" stroke="rgba(200,190,160,0.18)" stroke-width="1"/>
      <circle r="12" fill="rgba(200,190,160,0.1)" stroke="rgba(200,190,160,0.3)" stroke-width="1"/>
      <text y="36" text-anchor="middle" fill="rgba(200,190,160,0.65)" font-family="DM Mono, monospace" font-size="9" letter-spacing="0.06em">PATIENT AUTONOMY</text>
      <text y="47" text-anchor="middle" fill="rgba(200,190,160,0.4)" font-family="DM Mono, monospace" font-size="8">dignity · agency · wishes</text>
    </g>

    <!-- 7: Caregiver Burden -->
    <g class="node-interactive" data-node="caregiver" transform="translate(840,560)">
      <circle r="22" fill="rgba(200,190,160,0.05)" stroke="rgba(200,190,160,0.15)" stroke-width="1"/>
      <text y="32" text-anchor="middle" fill="rgba(200,190,160,0.55)" font-family="DM Mono, monospace" font-size="9" letter-spacing="0.05em">CAREGIVER BURDEN</text>
    </g>

    <!-- 8: Spiritual / Cultural -->
    <g class="node-interactive" data-node="spiritual" transform="translate(165,450)">
      <circle r="24" fill="rgba(200,190,160,0.05)" stroke="rgba(200,190,160,0.15)" stroke-width="1"/>
      <text y="-33" text-anchor="middle" fill="rgba(200,190,160,0.55)" font-family="DM Mono, monospace" font-size="9" letter-spacing="0.05em">SPIRITUAL / CULTURAL</text>
      <text y="-22" text-anchor="middle" fill="rgba(200,190,160,0.35)" font-family="DM Mono, monospace" font-size="8">ritual · meaning-making</text>
    </g>

    <!-- 9: Structural Inequity -->
    <g class="node-interactive" data-node="inequity" transform="translate(920,250)">
      <circle r="22" fill="rgba(200,190,160,0.04)" stroke="rgba(200,190,160,0.13)" stroke-width="1"/>
      <text y="-31" text-anchor="middle" fill="rgba(200,190,160,0.5)" font-family="DM Mono, monospace" font-size="9" letter-spacing="0.05em">STRUCTURAL</text>
      <text y="-20" text-anchor="middle" fill="rgba(200,190,160,0.5)" font-family="DM Mono, monospace" font-size="9" letter-spacing="0.05em">INEQUITY</text>
    </g>

    <!-- ======= CENTER: IMPENDING DEATH NODE ======= -->
    <circle cx="550" cy="340" r="80" fill="url(#center-glow)" opacity="0.8"/>
    <circle cx="550" cy="340" r="52" fill="rgba(200,180,130,0.05)" stroke="rgba(200,180,130,0.15)" stroke-width="1.5"/>
    <circle cx="550" cy="340" r="32" fill="rgba(200,180,130,0.07)" stroke="rgba(200,180,130,0.25)" stroke-width="1"/>
    <circle cx="550" cy="340" r="14" fill="rgba(200,180,130,0.12)" stroke="rgba(200,180,130,0.4)" stroke-width="1"/>
    <text x="550" y="336" text-anchor="middle" fill="#c8a96e" font-family="Cormorant Garamond, serif" font-size="13" font-weight="400" letter-spacing="0.04em">IMPENDING</text>
    <text x="550" y="352" text-anchor="middle" fill="#c8a96e" font-family="Cormorant Garamond, serif" font-size="13" font-style="italic" font-weight="300" letter-spacing="0.04em">death</text>

    <!-- Connector lines from system nodes to center -->
    <line x1="282" y1="280" x2="498" y2="338" stroke="rgba(200,190,160,0.12)" stroke-width="1" marker-end="url(#arrow-n)"/>
    <line x1="624" y1="200" x2="575" y2="308" stroke="rgba(200,190,160,0.12)" stroke-width="1" marker-end="url(#arrow-n)"/>
    <line x1="760" y1="380" x2="602" y2="353" stroke="rgba(200,190,160,0.12)" stroke-width="1" marker-end="url(#arrow-n)"/>
    <line x1="418" y1="172" x2="519" y2="308" stroke="rgba(200,190,160,0.12)" stroke-width="1" marker-end="url(#arrow-n)"/>
    <line x1="500" y1="480" x2="530" y2="392" stroke="rgba(200,190,160,0.12)" stroke-width="1" marker-end="url(#arrow-n)"/>
    <line x1="674" y1="490" x2="596" y2="378" stroke="rgba(200,190,160,0.12)" stroke-width="1" marker-end="url(#arrow-n)"/>
    <line x1="189" y1="450" x2="500" y2="360" stroke="rgba(200,190,160,0.08)" stroke-width="1" stroke-dasharray="2 3"/>

    <!-- ======= AUGMENTO MORI NODE ======= -->
    <!-- Glow halo -->
    <circle cx="310" cy="420" r="70" fill="url(#am-glow)" opacity="0.9"/>
    <!-- Outer ring animated -->
    <circle cx="310" cy="420" r="48" fill="none" stroke="rgba(196,81,58,0.3)" stroke-width="1" stroke-dasharray="6 4">
      <animateTransform attributeName="transform" type="rotate" from="0 310 420" to="360 310 420" dur="25s" repeatCount="indefinite"/>
    </circle>
    <circle cx="310" cy="420" r="36" fill="rgba(196,81,58,0.08)" stroke="#c4513a" stroke-width="1.5"/>
    <circle cx="310" cy="420" r="18" fill="rgba(196,81,58,0.15)" stroke="#c4513a" stroke-width="1"/>
    <!-- Icon: cards/game -->
    <rect x="304" y="413" width="6" height="8" rx="1" fill="none" stroke="#c4513a" stroke-width="1" transform="rotate(-8 307 417)"/>
    <rect x="307" y="412" width="6" height="8" rx="1" fill="none" stroke="#c4513a" stroke-width="1"/>
    <!-- Label -->
    <text x="310" y="473" text-anchor="middle" fill="#c4513a" font-family="Cormorant Garamond, serif" font-size="14" font-weight="400" letter-spacing="0.05em">Augmento Mori</text>
    <text x="310" y="486" text-anchor="middle" fill="rgba(196,81,58,0.7)" font-family="DM Mono, monospace" font-size="8.5" letter-spacing="0.08em">UPSTREAM INTERVENTION</text>
    <!-- Tag bubble -->
    <rect x="250" y="494" width="120" height="14" rx="7" fill="rgba(196,81,58,0.1)" stroke="rgba(196,81,58,0.2)" stroke-width="0.5"/>
    <text x="310" y="504" text-anchor="middle" fill="rgba(196,81,58,0.8)" font-family="DM Mono, monospace" font-size="8" letter-spacing="0.05em">death literacy · community</text>

    <!-- AM connections to system nodes -->
