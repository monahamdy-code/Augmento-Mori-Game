<script>
  const nodeData = {
    avoidance: {
      color: '#b0a888',
      tag: 'System Node · Reinforcing',
      title: 'Death Avoidance & Cultural Taboo',
      body: 'The primary driver of cultural silence around mortality. 78% of survey respondents avoid death conversations; early exclusion from death rituals (ages 4–12) creates lifelong communication barriers. Feeds R2 — the avoidance reinforcing loop.',
      pills: ['Cultural silence', 'Fear', 'Euphemism', '78% avoidance']
    },
    medicalization: {
      color: '#b0a888',
      tag: 'System Node · Reinforcing',
      title: 'Medicalization of Death',
      body: 'Over-medicalized end-of-life care removes death from homes and communities into clinical institutions. Creates overtreatment, moral distress among providers, and depersonalized dying. Central to R1 — the medicalization reinforcing loop.',
      pills: ['ICU overtreatment', 'Moral distress', 'De-personalization']
    },
    institutional: {
      color: '#b0a888',
      tag: 'System Node',
      title: 'Institutional Care Systems',
      body: 'Hospitals, hospice facilities, insurance structures, and policy frameworks that shape where and how people die. The Lancet Commission identifies institutional deaths as a key feedback driver — fewer home deaths means fewer witnesses, reducing community death literacy.',
      pills: ['Hospital death', 'Hospice', 'Insurance', 'Policy']
    },
    literacy: {
      color: '#b0a888',
      tag: 'System Node · Balancing',
      title: 'Death Literacy',
      body: 'Understanding, comfort, and knowledge about death and dying. 85% of survey respondents agree that open discussion reduces death-related fear. Activating this node creates B2 — the balancing loop that counters cultural avoidance.',
      pills: ['Education', '85% agree', 'Death positivity', 'Awareness']
    },
    community: {
      color: '#b0a888',
      tag: 'System Node · Balancing',
      title: 'Community Networks',
      body: 'Relational care networks — families, neighbors, grief groups, faith communities — that support dying and grieving outside institutional settings. Central to Kellehear\'s Public Health Palliative Care model. Feeds B1 — community care as systemic counterweight.',
      pills: ['Public health model', 'Grief rituals', 'Belonging', 'Relational care']
    },
    autonomy: {
      color: '#b0a888',
      tag: 'System Node',
      title: 'Patient Autonomy & Dignity',
      body: 'The dying person\'s capacity to make decisions, express preferences, and maintain identity. Only 42% of survey respondents have discussed end-of-life plans — exposing the communication gap between stated values and enacted behavior.',
      pills: ['Advance directives', 'Dignity', 'Agency', '42% plan gap']
    },
    caregiver: {
      color: '#b0a888',
      tag: 'System Node',
      title: 'Caregiver Burden',
      body: 'The invisible emotional, logistical, and physical labor borne by informal caregivers — family members who become sole communicators between patient and system. Distributed burden is a core design target for HeartBloom.',
      pills: ['Invisible labor', 'Burnout', 'Communication weight']
    },
    spiritual: {
      color: '#b0a888',
      tag: 'System Node',
      title: 'Spiritual & Cultural Dimensions',
      body: '79% of survey respondents report that spiritual or religious beliefs influence end-of-life decisions. Cultural death systems (Kastenbaum) include symbols, rituals, meaning-making practices. Anam Cara — Celtic soul-friend accompaniment — sits here as both methodology and design influence.',
      pills: ['79% influence', 'Ritual', 'Anam Cara', 'Meaning-making']
    },
    inequity: {
      color: '#b0a888',
      tag: 'System Node',
      title: 'Structural Inequity',
      body: 'Structural barriers — racial, economic, geographic — that determine differential access to quality end-of-life care. Dancing for Della workshop (Emory, Aug 2024) revealed how historical medical mistrust shapes Black communities\' palliative care engagement.',
      pills: ['Racial inequity', 'Tuskegee legacy', 'Access gap', 'Dancing for Della']
    }
  };

  const tooltip = document.getElementById('tooltip');
  const ttTag = document.getElementById('tt-tag');
  const ttTitle = document.getElementById('tt-title');
  const ttBody = document.getElementById('tt-body');
  const ttPills = document.getElementById('tt-pills');

  document.querySelectorAll('.node-interactive').forEach(node => {
    node.addEventListener('mouseenter', (e) => {
      const key = node.getAttribute('data-node');
      const data = nodeData[key];
      if (!data) return;
      ttTag.textContent = data.tag;
      ttTag.style.color = data.color;
      ttTitle.textContent = data.title;
      ttBody.textContent = data.body;
      ttPills.innerHTML = data.pills.map(p => `<span class="tooltip-pill">${p}</span>`).join('');
      tooltip.classList.add('visible');
    });

    node.addEventListener('mousemove', (e) => {
      let x = e.clientX + 16;
      let y = e.clientY + 16;
      if (x + 290 > window.innerWidth) x = e.clientX - 296;
      if (y + 200 > window.innerHeight) y = e.clientY - 200;
      tooltip.style.left = x + 'px';
      tooltip.style.top = y + 'px';
    });

    node.addEventListener('mouseleave', () => {
      tooltip.classList.remove('visible');
    });
  });
</script>
