<script>
const slides = document.querySelectorAll('.slide');
const ndots  = document.getElementById('ndots');
const pgbar  = document.getElementById('pgbar');
const ncnt   = document.getElementById('ncnt');
const total  = slides.length;

slides.forEach((_,i) => {
  const d = document.createElement('div');
  d.className = 'nav-dot';
  d.title = 'Slide ' + (i+1);
  d.addEventListener('click', () => slides[i].scrollIntoView({behavior:'smooth'}));
  ndots.appendChild(d);
});
const dots = document.querySelectorAll('.nav-dot');

// Intersection-based active + fade-in
const io = new IntersectionObserver(entries => {
  entries.forEach(e => {
    if (e.isIntersecting) {
      e.target.querySelectorAll('.fi').forEach((el,i) => {
        setTimeout(() => el.classList.add('vis'), i * 100);
      });
    }
  });
}, {threshold: 0.15});
slides.forEach(s => io.observe(s));

// scroll progress + nav counter
let cur = 0;
window.addEventListener('scroll', () => {
  const sy = window.scrollY;
  const dh = document.documentElement.scrollHeight - window.innerHeight;
  pgbar.style.width = Math.round((sy / dh) * 100) + '%';
  slides.forEach((slide, i) => {
    const r = slide.getBoundingClientRect();
    if (r.top <= window.innerHeight * 0.5 && r.bottom >= window.innerHeight * 0.5) {
      if (cur !== i) {
        dots[cur]?.classList.remove('active');
        dots[i]?.classList.add('active');
        ncnt.textContent = (i+1) + ' / ' + total;
        cur = i;
      }
    }
  });
}, {passive: true});
dots[0]?.classList.add('active');
</script>
